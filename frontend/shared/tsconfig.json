{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist",

    // Required for process.env
    "types": ["node"]
  },

  // Include entire shared source
  "include": ["src"],

  // Never compile built output
  "exclude": ["node_modules", "dist"]
}